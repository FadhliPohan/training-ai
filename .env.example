# ============================================================
# InsightFlow — Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository
# ============================================================

# ---- Server ----
APP_ENV=development
APP_PORT=8080

# ---- Database PostgreSQL ----
POSTGRES_USER=insightflow
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=insightflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://insightflow:ganti_dengan_password_kuat@localhost:5432/insightflow_db?sslmode=disable

# ---- JWT ----
# Wajib minimal 32 karakter acak — generate dengan: openssl rand -hex 32
JWT_SECRET=ganti_dengan_secret_minimal_32_karakter_acak_disini

# ---- n8n (Internal Network) ----
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=ganti_dengan_webhook_secret
N8N_DASHBOARD_WEBHOOK_PATH=/webhook/dashboard-ai
N8N_CHAT_WEBHOOK_PATH=/webhook/chat-ai

# ---- n8n Docker (untuk docker-compose) ----
N8N_USER=admin
N8N_PASSWORD=ganti_password_n8n

# ---- Frontend URL (untuk CORS) ----
FRONTEND_URL=http://localhost:3000

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=isi_dengan_token_dari_botfather
