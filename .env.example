# ============================================================
# InsightFlow — Root Environment Variables
# ============================================================
# 1) Salin file ini menjadi .env
# 2) Jangan commit file .env ke repository
# 3) Nilai di bawah cocok untuk docker-compose lokal

# ---- App ----
# development: auto-migrate default SKIP
# staging/production: auto-migrate default RUN
APP_ENV=development
APP_PORT=8080

# Optional override:
# AUTO_MIGRATE=true|false
AUTO_MIGRATE=false

# ---- PostgreSQL (docker-compose) ----
POSTGRES_USER=insightflow
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=insightflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://insightflow:ganti_dengan_password_kuat@localhost:5433/insightflow_db?sslmode=disable

# ---- JWT ----
# Minimal 32 karakter acak.
# Contoh generate: openssl rand -hex 32
JWT_SECRET=ganti_dengan_secret_minimal_32_karakter_acak_disini

# ---- n8n ----
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=ganti_dengan_webhook_secret
N8N_DASHBOARD_WEBHOOK_PATH=/webhook/dashboard-ai
N8N_CHAT_WEBHOOK_PATH=/webhook/chat-ai

# ---- n8n Basic Auth (docker-compose) ----
N8N_USER=admin
N8N_PASSWORD=ganti_password_n8n
N8N_HOST=localhost

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=isi_dengan_token_dari_botfather
