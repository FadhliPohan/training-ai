    {
      "id": "http-data",
      "name": "Get Report Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        280
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.url }}",
