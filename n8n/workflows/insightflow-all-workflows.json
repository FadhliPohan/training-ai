    "nodes": [
      {
        "id": "wh-dash",
        "name": "Webhook from Backend",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2,
        "position": [
          240,
          300
        ],
        "parameters": {
          "path": "dashboard-ai",
          "httpMethod": "POST",
          "responseMode": "responseNode",
          "options": {}
        }
      },
      {
        "id": "code-prompt",
        "name": "Format Analysis Prompt",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          460,
          300
        ],
        "parameters": {
          "jsCode": "const body = $input.first().json.body;\nconst { report_type, data, metrics, filters } = body;\n\nconst chartOptions = ['line', 'bar', 'pie', 'funnel', 'table'];\n\nconst prompt = `Kamu adalah analis data penjualan pakaian.\n\nTipe laporan: ${report_type}\nFilter periode: dari ${filters?.from || 'awal'} sampai ${filters?.to || 'sekarang'}\n${filters?.sales_id ? 'Filter sales_id: ' + filters.sales_id : ''}\n\nMetrics:\n${JSON.stringify(metrics, null, 2)}\n\nData sample (maksimal 10 baris):\n${JSON.stringify(Array.isArray(data) ? data.slice(0,10) : data, null, 2)}\n\nAnalisa data di atas dan kembalikan JSON valid berikut:\n{\n  \"chart_type\": \"${chartOptions.join('|')}\",\n  \"summary\": \"ringkasan 2-3 kalimat Bahasa Indonesia\",\n  \"anomalies\": [{\"metric\": \"\", \"actual\": 0, \"expected\": 0, \"variance_pct\": 0, \"description\": \"\"}],\n  \"recommendation\": \"1 kalimat saran tindakan konkret\"\n}\n\nKembalikan JSON valid saja, tanpa teks lain.`;\n\nreturn [{ json: { prompt, report_type } }];"
        }
      },
      {
        "id": "code-parse",
        "name": "Parse AI Response",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          900,
          300
        ],
        "parameters": {
          "jsCode": "const raw = $input.first().json.message.content.trim();\n\n// Fallback response\nconst fallback = {\n  chart_type: 'bar',\n  summary: 'Data tersedia namun analisis AI sedang tidak tersedia.',\n  anomalies: [],\n  recommendation: 'Silakan refresh atau coba beberapa saat lagi.'\n};\n\nlet parsed;\ntry {\n  // Strip markdown code block if present\n  const cleaned = raw.replace(/```json?/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = fallback;\n}\n\n// Validate required fields\nif (!parsed.chart_type || !parsed.summary) {\n  parsed = { ...fallback, ...parsed };\n}\n\n// Ensure anomalies is array\nif (!Array.isArray(parsed.anomalies)) {\n  parsed.anomalies = [];\n}\n\nreturn [{ json: parsed }];"
        }
      },
