      {
        "id": "code-parse",
        "name": "Extract Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          680,
          280
        ],
        "parameters": {
          "jsCode": "const body = $input.first().json.body;\nreturn [{\n  json: {\n    user_id: body.user_id,\n    user_nama: body.user_nama,\n    role: body.role,\n    chat_id: body.chat_id,\n    message_id: body.message_id,\n    message_text: body.message_text,\n    telegram_user_id: body.telegram_user_id\n  }\n}];"
        }
      },
      {
        "id": "code-url",
        "name": "Build Endpoint URL",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1120,
          280
        ],
        "parameters": {
          "jsCode": "const prev = $input.first().json;\nconst payload = $('Extract Payload').first().json;\n\nlet intentRaw = prev.message.content.trim();\n// Strip markdown code block if present\nintentRaw = intentRaw.replace(/```json?/g, '').replace(/```/g, '').trim();\n\nlet parsed;\ntry { parsed = JSON.parse(intentRaw); }\ncatch(e) { parsed = { intent: 'unknown', params: {} }; }\n\nconst { intent, params = {} } = parsed;\nconst BASE = 'http://localhost:8080';\nconst KEY='insightflow_internal_secret_key_change_in_production';\nconst threshold=($('Get Settings').first()?.json?.data?.anomaly_threshold_pct)||10;\n\nconst intentMap = {\n  daily_summary:       '/api/internal/reports/summary',\n  top_products:        '/api/internal/reports?type=top-products',\n  low_stock:           '/api/internal/reports?type=low-stock',\n  order_funnel:        '/api/internal/reports?type=order-funnel',\n  category_breakdown:  '/api/internal/reports?type=category-breakdown',\n  sales_performance:   '/api/internal/reports?type=sales-by-person',\n  monthly_sales:       '/api/internal/reports?type=monthly-sales',\n  revenue_trend:       '/api/internal/reports?type=revenue-trend',\n};\n\nif (intent === 'unknown' || !intentMap[intent]) {\n  return [{ json: {\n    unknown: true,\n    chat_id: payload.chat_id,\n    message_text: payload.message_text\n  }}];\n}\n\nlet url = BASE + intentMap[intent];\nconst qs = new URLSearchParams();\nif (params.from)     qs.set('from', params.from);\nif (params.to)       qs.set('to', params.to);\nif (params.sales_id) qs.set('sales_id', params.sales_id);\nif (qs.toString() && !url.includes('?')) url += '?' + qs.toString();\nelse if (qs.toString()) url += '&' + qs.toString();\n\nreturn [{ json: {\n  url, intent, params,\n  key: KEY,\n  chat_id: payload.chat_id,\n  user_nama: payload.user_nama,\n  role: payload.role,\n  message_text: payload.message_text,\n  unknown: false\n}}];"
        }
      },
