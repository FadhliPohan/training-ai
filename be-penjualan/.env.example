# ============================================================
# InsightFlow Backend (.env.example)
# ============================================================
# Salin file ini menjadi be-penjualan/.env

# ---- App ----
# development: auto-migrate default SKIP
# staging/production: auto-migrate default RUN
APP_ENV=development
APP_PORT=8080
AUTO_MIGRATE=false

# ---- Database ----
DATABASE_URL=postgres://insightflow:insightflow123@localhost:5433/insightflow_db?sslmode=disable

# ---- Security ----
# Wajib minimal 32 karakter
JWT_SECRET=this_is_a_very_long_secret_key_that_is_at_least_32_characters_long_for_jwt_signing

# ---- n8n ----
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=replace_me_with_secure_secret
N8N_DASHBOARD_WEBHOOK_PATH=/webhook/dashboard-ai
N8N_CHAT_WEBHOOK_PATH=/webhook/chat-ai

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:3000

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
